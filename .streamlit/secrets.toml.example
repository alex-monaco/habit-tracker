# Copy this file to secrets.toml and fill in real values.
# secrets.toml is gitignored. In production, paste these into
# Streamlit Cloud's app Settings -> Secrets UI instead.

ALLOWED_EMAILS = ["you@gmail.com"]

# Set to true to bypass Google OAuth (local dev only). Remove or set false in production.
HABIT_DEV_MODE = true

# Path to your Obsidian vault — read by extract_habits.py directly from this file
VAULT_DIR = "/Users/you/MyVault"

# Set to true on Streamlit Cloud to hide the "Extract latest" button (vault not accessible remotely).
# Leave unset or false for local development.
REMOTE_MODE = false

# Supabase credentials for remote data storage.
# When set, the app reads/writes habit data from Supabase instead of local files.
# Create a free project at supabase.com, add a `habit_data` table with
# `filename` (text, primary key) and `data` (jsonb) columns.
SUPABASE_URL = "https://your-project-id.supabase.co"
SUPABASE_KEY = "your-secret-key"

[auth]
redirect_uri = "http://localhost:8501/oauth2callback"
cookie_secret = "generate-with-python-c-import-secrets-print-secrets-token_hex-32"
client_id = "from-google-cloud-console"
client_secret = "from-google-cloud-console"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"
